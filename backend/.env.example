# API Configuration
APP_NAME="Chatbot Tourisme Bénin"
APP_VERSION="1.0.0"
DEBUG=True
PORT=8000

# CORS - Frontend URL (change for production)
FRONTEND_URL=http://localhost:5173

# LLM Provider (choose one)
# Option 1: Groq (Recommended - Fast & Free)
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
LLM_MODEL=mixtral-8x7b-32768

# Option 2: OpenAI (Alternative)
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-3.5-turbo

# Embeddings Provider
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./app/data/processed/chroma_db
COLLECTION_NAME=benin_tourism_knowledge

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
TEMPERATURE=0.7
MAX_TOKENS=1000

# Scraping Configuration (optional rate limiting)
SCRAPING_DELAY=1.0
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
